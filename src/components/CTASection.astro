---
interface Props {
  title?: string;
  primaryText?: string;
  primaryLink?: string;
  secondaryText?: string;
  secondaryLink?: string;
}
const {
  title = '觉得有用？看看我的书和课程',
  primaryText = '选择改变命运',
  primaryLink = '/book',
  secondaryText = '写作课程',
  secondaryLink = '/community',
} = Astro.props;
---

<div class="cta-box">
  <p>{title}</p>
  <div class="cta-buttons">
    <a href={primaryLink} class="cta-btn cta-btn-primary">{primaryText}</a>
    <a href={secondaryLink} class="cta-btn cta-btn-secondary">{secondaryText}</a>
  </div>
</div>

<style>
  .cta-box {
    margin-top: 48px;
    padding: 32px;
    background: var(--color-card-bg, #fafafa);
    border-radius: 12px;
    text-align: center;
    border: 1px solid var(--color-border, #e5e5e5);
  }
  .cta-box > p {
    font-size: 1.1rem;
    font-weight: 500;
    margin-bottom: 20px;
    color: var(--color-text, #111);
  }
  .cta-buttons {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .cta-btn {
    display: inline-block;
    padding: 10px 24px;
    border-radius: 8px;
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    transition: opacity 0.2s;
  }
  .cta-btn:hover { opacity: 0.85; }
  .cta-btn-primary {
    background: var(--color-accent, #f55000);
    color: #fff;
  }
  .cta-btn-secondary {
    background: transparent;
    color: var(--color-text, #111);
    border: 1px solid var(--color-border, #e5e5e5);
  }
</style>
