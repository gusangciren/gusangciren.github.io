---
interface Props {
  title?: string;
  primaryText?: string;
  primaryLink?: string;
  secondaryText?: string;
  secondaryLink?: string;
}
const {
  title = '觉得有用？看看我的书和课程',
  primaryText = '选择改变命运',
  primaryLink = '/book',
  secondaryText = '写作课程',
  secondaryLink = '/community',
} = Astro.props;
---

<div class="cta-box">
  <p>{title}</p>
  <div class="cta-buttons">
    <a href={primaryLink} class="cta-btn cta-btn-primary">{primaryText}</a>
    <a href={secondaryLink} class="cta-btn cta-btn-secondary">{secondaryText}</a>
  </div>
</div>
