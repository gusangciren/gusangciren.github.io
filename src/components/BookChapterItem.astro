---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../utils/formatDate';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, date, description, slug } = post.data;
---

<a href={`/blog/${slug}`} class="book-chapter-item">
  <span class="chapter-num">{post.data.seriesOrder?.toString().padStart(2, '0') || '—'}</span>
  <div class="chapter-info">
    <strong>{title}</strong>
    {description && <p>{description}</p>}
  </div>
</a>

<style>
  .book-chapter-item {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 14px 16px;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--color-border, #e5e5e5);
    border-radius: 8px;
    transition: border-color 0.2s, background 0.2s;
  }
  .book-chapter-item:hover {
    border-color: var(--color-accent, #f55000);
    background: rgba(245, 80, 0, 0.02);
  }
  .chapter-num {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: var(--color-bg, #f5f5f5);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text-secondary, #888);
  }
  .chapter-info strong {
    display: block;
    font-size: 15px;
    font-weight: 600;
    margin-bottom: 2px;
  }
  .chapter-info p {
    font-size: 13px;
    color: var(--color-text-secondary, #888);
    margin: 0;
    line-height: 1.5;
  }
</style>
