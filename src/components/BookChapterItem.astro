---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../utils/formatDate';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, date, description, slug } = post.data;
---

<a href={`/blog/${slug}`} class="book-chapter-item">
  <span class="chapter-num">{post.data.seriesOrder?.toString().padStart(2, '0') || '—'}</span>
  <div class="chapter-info">
    <strong>{title}</strong>
    {description && <p>{description}</p>}
  </div>
</a>
