---
export interface Props {
  title: string;
  description?: string;
}

const { title, description = '像企业家一样写作 — 用写作构建你的个人品牌和商业系统' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>
  <body>
    <nav class="navbar">
      <div class="nav-inner">
        <a href="/" class="logo">像企业家一样写作</a>
        <div class="nav-links">
          <a href="/blog">文章</a>
          <a href="/book">书籍</a>
          <a href="/community">社群</a>
        </div>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      <div class="footer-inner">
        <p>© 2026 像企业家一样写作</p>
        <div class="footer-links">
          <a href="https://mp.weixin.qq.com/" target="_blank">公众号：巨人的方法</a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400;600;700&display=swap');

  :root {
    --color-bg: #fafaf9;
    --color-text: #1c1917;
    --color-text-secondary: #78716c;
    --color-accent: #F55000;
    --color-border: #e7e5e4;
    --color-card-bg: #ffffff;
    --max-width: 720px;
    --font-serif: 'Noto Serif SC', 'Source Han Serif SC', serif;
    --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: var(--font-sans);
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.8;
    -webkit-font-smoothing: antialiased;
  }

  /* Navbar */
  .navbar {
    position: sticky;
    top: 0;
    background: rgba(250, 250, 249, 0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    z-index: 100;
  }
  .nav-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 24px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo {
    font-family: var(--font-serif);
    font-size: 16px;
    font-weight: 300;
    letter-spacing: 0.08em;
    color: var(--color-text);
    text-decoration: none;
  }
  .nav-links {
    display: flex;
    gap: 32px;
  }
  .nav-links a {
    font-size: 14px;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover {
    color: var(--color-accent);
  }

  /* Main */
  main {
    min-height: calc(100vh - 56px - 80px);
  }

  /* Footer */
  footer {
    border-top: 1px solid var(--color-border);
    padding: 24px;
    margin-top: 80px;
  }
  .footer-inner {
    max-width: 960px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    color: var(--color-text-secondary);
  }
  .footer-links a {
    color: var(--color-text-secondary);
    text-decoration: none;
  }
  .footer-links a:hover {
    color: var(--color-accent);
  }

  /* Article styles */
  .prose {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 24px;
  }
  .prose h1 {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 600;
    margin: 2em 0 0.8em;
    line-height: 1.3;
  }
  .prose h2 {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 600;
    margin: 1.8em 0 0.6em;
    line-height: 1.4;
  }
  .prose h3 {
    font-size: 1.2rem;
    font-weight: 600;
    margin: 1.5em 0 0.4em;
  }
  .prose p {
    margin: 1em 0;
    font-size: 16px;
    line-height: 1.9;
  }
  .prose a {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid rgba(245, 80, 0, 0.3);
    transition: border-color 0.2s;
  }
  .prose a:hover {
    border-bottom-color: var(--color-accent);
  }
  .prose img {
    max-width: 100%;
    border-radius: 8px;
    margin: 1.5em 0;
  }
  .prose blockquote {
    border-left: 3px solid var(--color-accent);
    padding: 0.5em 1em;
    margin: 1.5em 0;
    color: var(--color-text-secondary);
    background: rgba(245, 80, 0, 0.04);
    border-radius: 0 6px 6px 0;
  }
  .prose ul, .prose ol {
    padding-left: 1.5em;
    margin: 1em 0;
  }
  .prose li {
    margin: 0.3em 0;
  }
  .prose code {
    background: #f5f5f4;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
  }
  .prose pre {
    background: #1c1917;
    color: #e7e5e4;
    padding: 1em;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5em 0;
  }
  .prose pre code {
    background: none;
    padding: 0;
    color: inherit;
  }
  .prose strong {
    font-weight: 600;
  }

  /* CTA */
  .cta-box {
    max-width: var(--max-width);
    margin: 3em auto;
    padding: 2em;
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    text-align: center;
  }
  .cta-box p {
    color: var(--color-text-secondary);
    margin-bottom: 1em;
    font-size: 15px;
  }
  .cta-button {
    display: inline-block;
    padding: 10px 28px;
    background: var(--color-accent);
    color: white;
    text-decoration: none;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 500;
    transition: opacity 0.2s;
  }
  .cta-button:hover {
    opacity: 0.9;
  }

  @media (max-width: 640px) {
    .nav-inner { padding: 0 16px; }
    .nav-links { gap: 20px; }
    .prose { padding: 0 16px; }
    .prose h1 { font-size: 1.6rem; }
    .footer-inner { flex-direction: column; gap: 8px; text-align: center; }
  }
</style>
