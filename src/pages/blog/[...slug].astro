---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Find next post in series
let nextPost = null;
if (post.data.series && post.data.seriesOrder) {
  const allPosts = await getCollection('blog');
  const seriesPosts = allPosts.filter(
    p => p.data.series === post.data.series && p.data.seriesOrder
  );
  seriesPosts.sort((a, b) => a.data.seriesOrder - b.data.seriesOrder);
  
  const currentIndex = seriesPosts.findIndex(p => p.data.slug === post.data.slug);
  if (currentIndex >= 0 && currentIndex < seriesPosts.length - 1) {
    nextPost = seriesPosts[currentIndex + 1];
  }
}
---

<BaseLayout title={`${post.data.title} — 像企业家一样写作`}>
  <article class="prose">
    <header class="article-header">
      <h1>{post.data.title}</h1>
      <div class="article-meta">
        {post.data.series && (
          <span class="article-series">📚 {post.data.series}</span>
        )}
        <time>
          {new Date(post.data.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </div>
    </header>
    <Content />

    {nextPost && (
      <div class="next-chapter">
        <a href={`/blog/${nextPost.data.slug}`} class="next-chapter-link">
          <span class="next-label">下一章</span>
          <span class="next-title">{nextPost.data.title}</span>
          <span class="next-arrow">→</span>
        </a>
      </div>
    )}

    <div class="cta-box">
      <p>觉得有用？看看我的书和课程</p>
      <div class="cta-buttons">
        <a href="/book" class="cta-btn cta-btn-primary">
          <span class="cta-icon">📖</span>
          <span class="cta-text">选择改变命运</span>
        </a>
        <a href="/community" class="cta-btn cta-btn-secondary">
          <span class="cta-icon">🎓</span>
          <span class="cta-text">写作课程</span>
        </a>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .article-header { margin: 48px 0 32px; }
  .article-header h1 {
    font-family: var(--font-serif); font-size: 2rem;
    font-weight: 600; line-height: 1.3; margin-bottom: 12px;
  }
  .article-meta {
    font-size: 14px; color: var(--color-text-secondary);
    display: flex; gap: 16px; align-items: center;
  }
  .article-series {
    background: rgba(245, 80, 0, 0.08); padding: 2px 10px;
    border-radius: 4px; font-size: 13px;
  }

  /* Next Chapter Navigation */
  .next-chapter {
    margin: 3em 0 2em;
    padding: 0 24px;
  }
  .next-chapter-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 16px 24px;
    background: var(--color-card-bg);
    border: 1px solid var(--color-accent);
    border-radius: 10px;
    text-decoration: none;
    color: var(--color-accent);
    transition: all 0.2s ease;
  }
  .next-chapter-link:hover {
    background: var(--color-accent);
    color: white;
  }
  .next-label {
    font-size: 14px;
    font-weight: 500;
    white-space: nowrap;
  }
  .next-title {
    font-family: var(--font-serif);
    font-size: 16px;
    font-weight: 600;
    flex: 1;
    text-align: center;
  }
  .next-arrow {
    font-size: 18px;
    transition: transform 0.2s;
  }
  .next-chapter-link:hover .next-arrow {
    transform: translateX(4px);
  }

  .cta-buttons {
    display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;
  }
  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 28px;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
    min-width: 140px;
    justify-content: center;
  }
  .cta-btn-primary {
    background: var(--color-accent);
    color: white;
  }
  .cta-btn-primary:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }
  .cta-btn-secondary {
    background: #1c1917;
    color: white;
  }
  .cta-btn-secondary:hover {
    background: #2d2a26;
    transform: translateY(-1px);
  }
  .cta-icon {
    font-size: 1.1em;
  }
  .cta-text {
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .next-chapter {
      padding: 0 16px;
    }
    .next-chapter-link {
      flex-direction: column;
      gap: 8px;
      padding: 16px;
    }
    .next-title {
      text-align: center;
    }
  }
</style>
