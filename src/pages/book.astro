---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import BookChapterItem from '../components/BookChapterItem.astro';

const books = await getCollection('books');
const posts = await getCollection('blog');

// Sort books by order
books.sort((a, b) => a.data.order - b.data.order);

// For each book, find its chapters from blog collection
const booksWithChapters = books.map(book => {
  const chapters = posts
    .filter(p => p.data.series === book.data.seriesName && p.data.seriesOrder)
    .sort((a, b) => a.data.seriesOrder! - b.data.seriesOrder!);
  return { book, chapters };
});
---

<BaseLayout title="书籍 — 像企业家一样写作">
  <div class="book-page">
    {booksWithChapters.map(({ book, chapters }) => (
      <div id={book.slug} class="book-section">
        <div class="book-hero">
          <div class="book-cover">
            <img src={book.data.cover} alt={book.data.title} class="book-cover-img" />
          </div>
          <div class="book-details">
            <h1>《{book.data.title}》</h1>
            {book.data.subtitle && <p class="tagline">{book.data.subtitle}</p>}
            {book.data.motto && <p class="motto">「{book.data.motto}」</p>}
            <p>{book.data.description}</p>
          </div>
        </div>

        {chapters.length > 0 && (
          <div class="chapters">
            <h2>全书{chapters.length}章</h2>
            <div class="chapter-grid">
              {chapters.map(chapter => (
                <BookChapterItem post={chapter} />
              ))}
            </div>
          </div>
        )}
      </div>
    ))}
  </div>
</BaseLayout>

<style is:global>
  .book-page {
    max-width: 960px;
    margin: 0 auto;
    padding: 40px 24px 80px;
  }
  .book-section {
    margin-bottom: 64px;
  }
  .book-divider {
    border: none;
    border-top: 1px solid var(--color-border, #e5e5e5);
    margin: 64px 0;
  }
  .book-hero {
    display: flex;
    gap: 32px;
    align-items: flex-start;
    margin-bottom: 40px;
  }
  .book-cover {
    flex-shrink: 0;
  }
  .book-cover-img {
    width: 160px;
    height: auto;
    border-radius: 8px;
    box-shadow: 0 8px 28px rgba(0,0,0,0.12), 0 2px 8px rgba(0,0,0,0.06);
  }
  .book-details h1 {
    font-family: var(--font-serif, Georgia, serif);
    font-size: 1.6rem;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .tagline {
    font-size: 1rem;
    color: var(--color-accent, #f55000);
    font-weight: 500;
    margin-bottom: 8px;
  }
  .motto {
    font-size: 0.95rem;
    color: var(--color-text-secondary, #888);
    font-style: italic;
    margin-bottom: 16px;
  }
  .book-details > p:last-child {
    font-size: 15px;
    color: var(--color-text-secondary, #888);
    line-height: 1.8;
  }
  .chapters {
    margin-top: 40px;
  }
  .chapters h2 {
    font-family: var(--font-serif, Georgia, serif);
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 2px solid var(--color-accent, #f55000);
    display: inline-block;
  }
  .chapter-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 12px;
  }

  @media (max-width: 640px) {
    .book-hero {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .book-cover-img {
      width: 120px;
    }
  }
</style>
