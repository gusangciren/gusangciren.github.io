---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import BookChapterItem from '../components/BookChapterItem.astro';

const books = await getCollection('books');
const posts = await getCollection('blog');

books.sort((a, b) => a.data.order - b.data.order);

// For each book, find its chapters from blog collection
const booksWithChapters = books.map(book => {
  const chapters = posts
    .filter(p => p.data.series === book.data.seriesName && p.data.seriesOrder)
    .sort((a, b) => a.data.seriesOrder! - b.data.seriesOrder!);
  const slug = book.id.replace(/\.(md|mdx)$/i, '');
  return { book, chapters, slug };
});
---

<BaseLayout title="书籍 — 像企业家一样写作">
  <div class="book-page">
    {booksWithChapters.map(({ book, chapters, slug }) => (
      <div id={slug} class="book-section">
        <div class="book-hero">
          <div class="book-cover">
            <img src={book.data.cover} alt={book.data.title} class="book-cover-img" />
          </div>
          <div class="book-details">
            <h1>《{book.data.title}》</h1>
            {book.data.subtitle && <p class="tagline">{book.data.subtitle}</p>}
            {book.data.motto && <p class="motto">「{book.data.motto}」</p>}
            <p>{book.data.description}</p>

            {chapters.length > 0 && (
              <div class="chapters-nav">
                <a href={`/book/${slug}`} class="view-chapters-btn">
                  {book.data.chapterSize
                    ? `查看章节一览（${Math.ceil(chapters.length / book.data.chapterSize)}章 / ${chapters.length}篇） →`
                    : `查看全部文章（${chapters.length}篇） →`}
                </a>
              </div>
            )}
          </div>
        </div>

        {/* 普通书籍：直接在列表页展示文章（最多显示6篇预览） */}
        {!book.data.chapterSize && chapters.length > 0 && (
          <div class="chapters">
            <div class="chapter-grid">
              {chapters.slice(0, 6).map(chapter => (
                <BookChapterItem post={chapter} />
              ))}
            </div>
            {chapters.length > 6 && (
              <div style="text-align: center; margin-top: 16px;">
                <a href={`/book/${slug}`} style="color: var(--color-accent, #f55000); font-size: 0.85rem; text-decoration: none;">
                  还有 {chapters.length - 6} 篇文章 →
                </a>
              </div>
            )}
          </div>
        )}
      </div>
    ))}
  </div>
</BaseLayout>

<style is:global>
  .book-page {
    max-width: 960px;
    margin: 0 auto;
    padding: 40px 24px 80px;
  }
  .book-section {
    margin-bottom: 64px;
  }
  .book-divider {
    border: none;
    border-top: 1px solid var(--color-border, #e5e5e5);
    margin: 64px 0;
  }
  .book-hero {
    display: flex;
    gap: 32px;
    align-items: flex-start;
    margin-bottom: 40px;
  }
  .book-cover {
    flex-shrink: 0;
  }
  .book-cover-img {
    width: 160px;
    height: auto;
    border-radius: 8px;
    box-shadow: 0 8px 28px rgba(0,0,0,0.12), 0 2px 8px rgba(0,0,0,0.06);
  }
  .book-details h1 {
    font-family: var(--font-serif, Georgia, serif);
    font-size: 1.6rem;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .tagline {
    font-size: 1rem;
    color: var(--color-accent, #f55000);
    font-weight: 500;
    margin-bottom: 8px;
  }
  .motto {
    font-size: 0.95rem;
    color: var(--color-text-secondary, #888);
    font-style: italic;
    margin-bottom: 16px;
    padding-left: 14px;
    border-left: 3px solid var(--color-accent, #f55000);
  }
  .book-details > p:last-child {
    font-size: 15px;
    color: var(--color-text-secondary, #888);
    line-height: 1.8;
  }
  .chapters-nav {
    margin-top: 20px;
  }
  .view-chapters-btn {
    display: inline-block;
    padding: 10px 20px;
    background: var(--color-accent-light, #fff5f0);
    border: 1px solid rgba(245,80,0,0.2);
    border-radius: 8px;
    color: var(--color-accent, #f55000);
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 500;
    transition: all 0.2s;
  }
  .view-chapters-btn:hover {
    background: var(--color-accent, #f55000);
    color: white;
    border-color: var(--color-accent, #f55000);
  }
  .chapters {
    margin-top: 40px;
  }
  .chapters h2 {
    font-family: var(--font-serif, Georgia, serif);
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 2px solid var(--color-accent, #f55000);
    display: inline-block;
  }
  .chapter-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 12px;
  }

  @media (max-width: 640px) {
    .book-hero {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .book-cover-img {
      width: 120px;
    }
  }
</style>
