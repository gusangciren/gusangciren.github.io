---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import PostCard from '../components/PostCard.astro';
import CTASection from '../components/CTASection.astro';

import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const filteredPosts = posts.filter(p => p.data.series !== '第一个100块' && p.data.series !== '选择改变命运');
const sortedPosts = filteredPosts.sort((a, b) => new Date(b.data.date) - new Date(a.data.date));

const { featured = posts.slice(0, 6) } = Astro.props;
---

<BaseLayout title="像企业家一样写作">
  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <h1>Build, sell, write, create, invest, and own.</h1>
      <p class="hero-cn">构建，销售，写作，创造，投资，掌控。</p>
      <p class="hero-habit">Make these habits.</p>
      <p class="hero-habit-cn">保持这些习惯。</p>
      <div class="hero-actions">
        <a href="/blog" class="btn-primary">读文章</a>
        <a href="/book" class="btn-secondary">看书籍</a>
        <a href="/community" class="btn-secondary">加入社群</a>
      </div>
    </div>
  </section>

  <!-- Books Preview -->
  <section class="section section-books">
    <div class="section-inner">
      <SectionHeader title="书籍作品" link="/book" />
      <div class="books-preview">
        <a href="/book#choice-changes-fate" class="book-preview-card">
          <img src="/images/book1-cover.png" alt="选择改变命运" class="book-preview-cover" />
          <div>
            <h3>《选择改变命运》</h3>
            <p>靠学识赢得未来</p>
          </div>
        </a>
        <a href="/book#first-100-yuan" class="book-preview-card">
          <img src="/images/book2-cover.png" alt="第一个100块" class="book-preview-cover" />
          <div>
            <h3>《第一个100块》</h3>
            <p>从0到1的内容变现闭环</p>
          </div>
        </a>
        <a href="/book#paul-graham-essays" class="book-preview-card">
          <img src="/images/pg-cover.png" alt="Paul Graham 文集" class="book-preview-cover" />
          <div>
            <h3>Paul Graham 文集</h3>
            <p>185篇深度思考全译本</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Community Preview -->
  <section class="section">
    <div class="section-inner">
      <div class="community-preview">
        <div class="community-cards">
          <div class="community-card">
            <div class="community-icon">✉</div>
            <h4>UAC 周刊</h4>
            <p>每周四推送，不被算法过滤的深度文章，直达邮箱</p>
          </div>
          <div class="community-card">
            <div class="community-icon">✎</div>
            <h4>写作课程</h4>
            <p>系统学习企业家式写作，一起成长</p>
          </div>
        </div>
        <div class="community-cta">
          <div class="community-stat">
            已有 <span class="stat-number">84+</span> 位同学加入
          </div>
          <a href="/community" class="btn-primary">了解详情</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Articles -->
  <section class="section">
    <div class="section-inner">
      <SectionHeader title="最新文章" link="/blog" />
      <div class="card-grid">
        {sortedPosts.slice(0, 6).map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="section-inner">
      <CTASection />
    </div>
  </section>
</BaseLayout>
