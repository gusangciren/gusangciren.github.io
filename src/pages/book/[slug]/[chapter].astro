---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const books = await getCollection('books');
  const posts = await getCollection('blog');
  const paths = [];

  for (const book of books) {
    const bookSlug = book.slug || (book.id && book.id.replace(/\.(md|mdx)$/i, ''));
    if (!bookSlug) continue;

    const chapterSize = book.data.chapterSize;
    if (!chapterSize) continue; // 只有有 chapterSize 的书才生成章节页面

    const chapters = posts
      .filter(p => p.data.series === book.data.seriesName && p.data.seriesOrder)
      .sort((a, b) => a.data.seriesOrder! - b.data.seriesOrder!);

    if (chapters.length === 0) continue;

    const maxOrder = Math.max(...chapters.map(p => p.data.seriesOrder!));
    const totalChapters = Math.ceil(maxOrder / chapterSize);

    for (let i = 0; i < totalChapters; i++) {
      const start = i * chapterSize + 1;
      const end = Math.min((i + 1) * chapterSize, maxOrder);
      paths.push({
        params: { slug: bookSlug, chapter: `${start}-${end}` },
        props: { bookSlug, start, end, chapterSize },
      });
    }
  }
  return paths;
}

const { slug, chapter } = Astro.params;
const { start, end, chapterSize } = Astro.props;

const books = await getCollection('books');
const book = books.find(b => {
  const bookSlug = b.slug || (b.id && b.id.replace(/\.(md|mdx)$/i, ''));
  return bookSlug === slug;
});

const posts = await getCollection('blog');
const chapterPosts = posts
  .filter(p =>
    p.data.series === book?.data.seriesName &&
    p.data.seriesOrder &&
    p.data.seriesOrder >= start &&
    p.data.seriesOrder <= end
  )
  .sort((a, b) => a.data.seriesOrder! - b.data.seriesOrder!);

const chapterNum = Math.ceil(start / chapterSize);
---
<BaseLayout title={`第${chapterNum}章 — ${book?.data.title || ''} — 书籍`}>
  <div class="chapter-detail-page">
    <a href={`/book/${slug}`} class="back-link">← 返回章节一览</a>

    <div class="chapter-header">
      <div class="big-num">{chapterNum}</div>
      <div>
        <div class="chapter-title">第{chapterNum}章：{start}-{end}篇</div>
        <div class="chapter-count">共 {chapterPosts.length} 篇文章</div>
      </div>
    </div>

    {chapterPosts.length > 0 ? (
      <div class="article-list">
        {chapterPosts.map(post => (
          <a href={`/blog/${post.data.slug}`} class="article-item">
            <span class="article-num">{String(post.data.seriesOrder).padStart(3, '0')}</span>
            <span class="article-title">{post.data.title}</span>
            {post.data.date && (
              <span class="article-date">
                {new Date(post.data.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' })}
              </span>
            )}
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-chapter">
        <p>该章节的文章尚未上传，敬请期待。</p>
      </div>
    )}
  </div>
</BaseLayout>

<style is:global>
  .chapter-detail-page { max-width: 960px; margin: 0 auto; padding: 100px 24px 80px; }
  .back-link { display: inline-flex; align-items: center; gap: 6px; font-size: 0.85rem; color: var(--color-text-secondary, #888); text-decoration: none; margin-bottom: 24px; transition: color 0.2s; }
  .back-link:hover { color: var(--color-accent, #f55000); }
  .chapter-header { display: flex; align-items: center; gap: 20px; margin-bottom: 32px; padding-bottom: 20px; border-bottom: 1px solid var(--color-border, #e5e5e5); }
  .big-num { font-family: var(--font-serif, Georgia, serif); font-size: 3.5rem; font-weight: 700; color: var(--color-accent, #f55000); opacity: 0.15; line-height: 1; }
  .chapter-title { font-family: var(--font-serif, Georgia, serif); font-size: 1.5rem; font-weight: 600; }
  .chapter-count { font-size: 0.85rem; color: var(--color-text-secondary, #888); margin-top: 4px; }
  .article-list { display: flex; flex-direction: column; gap: 6px; }
  .article-item { display: flex; align-items: center; gap: 14px; padding: 14px 18px; border: 1px solid transparent; border-radius: 8px; text-decoration: none; color: var(--color-text, #1a1a1a); transition: all 0.15s; }
  .article-item:hover { background: var(--color-accent-light, #fff5f0); border-color: rgba(245,80,0,0.12); }
  .article-num { flex-shrink: 0; width: 36px; height: 32px; border-radius: 8px; background: var(--color-bg, #fafafa); display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 600; color: var(--color-text-secondary, #888); }
  .article-item:hover .article-num { background: rgba(245,80,0,0.1); color: var(--color-accent, #f55000); }
  .article-title { flex: 1; font-size: 0.92rem; font-weight: 500; }
  .article-item:hover .article-title { color: var(--color-accent, #f55000); }
  .article-date { font-size: 0.75rem; color: var(--color-text-secondary, #888); flex-shrink: 0; }
  .empty-chapter { text-align: center; padding: 60px 20px; color: var(--color-text-secondary, #888); font-size: 0.95rem; }
  @media (max-width: 640px) {
    .chapter-detail-page { padding-top: 80px; }
    .chapter-header { flex-direction: column; align-items: flex-start; gap: 8px; }
    .big-num { font-size: 2.5rem; }
  }
</style>
