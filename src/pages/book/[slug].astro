---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books
    .filter(b => b.id)
    .map(book => {
      const slug = book.slug || book.id.replace(/\.(md|mdx)$/i, '');
      return { params: { slug } };
    });
}

const { slug } = Astro.params;
const books = await getCollection('books');
const posts = await getCollection('blog');

const book = books.find(b => {
  const bookSlug = b.slug || (b.id && b.id.replace(/\.(md|mdx)$/i, ''));
  return bookSlug === slug;
});
if (!book) throw new Error(`Book not found: ${slug}`);

const chapters = posts
  .filter(p => p.data.series === book.data.seriesName && p.data.seriesOrder)
  .sort((a, b) => a.data.seriesOrder! - b.data.seriesOrder!);

// 判断展示模式：有 chapterSize 的书用章节折叠，没有的用文章平铺
const chapterSize = book.data.chapterSize;

// 章节折叠模式：按 chapterSize 分组
let chapterGroups: { start: number; end: number; posts: typeof chapters }[] = [];
if (chapterSize && chapters.length > 0) {
  const maxOrder = Math.max(...chapters.map(p => p.data.seriesOrder!));
  const totalChapters = Math.ceil(maxOrder / chapterSize);
  for (let i = 0; i < totalChapters; i++) {
    const start = i * chapterSize + 1;
    const end = Math.min((i + 1) * chapterSize, maxOrder);
    const groupPosts = chapters.filter(p => {
      const o = p.data.seriesOrder!;
      return o >= start && o <= end;
    });
    chapterGroups.push({ start, end, posts: groupPosts });
  }
}
---
<BaseLayout title={`${book.data.title} — 书籍 — 像企业家一样写作`}>
  <div class="book-page">
    <div class="book-hero">
      <div class="book-cover">
        <img src={book.data.cover} alt={book.data.title} class="book-cover-img" />
      </div>
      <div class="book-details">
        <div class="book-tag">{book.data.seriesName}</div>
        <h1>《{book.data.title}》</h1>
        {book.data.subtitle && <p class="tagline">{book.data.subtitle}</p>}
        {book.data.motto && <p class="motto">「{book.data.motto}」</p>}
        <p class="desc">{book.data.description}</p>
        <div class="book-stats">
          <div class="stat">
            <div class="stat-num">{chapters.length}</div>
            <div class="stat-label">篇文章</div>
          </div>
          {chapterSize && (
            <div class="stat">
              <div class="stat-num">{chapterGroups.length}</div>
              <div class="stat-label">个章节</div>
            </div>
          )}
        </div>
      </div>
    </div>

    {chapterSize ? (
      // ===== 章节折叠模式（如 PG 文集）=====
      chapterGroups.length > 0 && (
        <div class="chapters-section">
          <div class="section-header">
            <h2>章节一览</h2>
            <span class="count">共 {chapterGroups.length} 章 · {chapters.length} 篇文章</span>
          </div>
          <div class="chapter-grid">
            {chapterGroups.map((group, i) => (
              <a href={`/book/${slug}/${group.start}-${group.end}`} class="chapter-card">
                <div class="chapter-num">{String(i + 1).padStart(2, '0')}</div>
                <div class="chapter-info">
                  <div class="chapter-name">第{i + 1}章：{group.start}-{group.end}篇</div>
                  <div class="chapter-desc">
                    {group.posts.length > 0
                      ? group.posts.slice(0, 3).map(p => p.data.title).join(' · ') + (group.posts.length > 3 ? '…' : '')
                      : '尚未上传'}
                  </div>
                </div>
                <div class="chapter-count">{group.posts.length}篇</div>
                <div class="chapter-arrow">→</div>
              </a>
            ))}
          </div>
        </div>
      )
    ) : (
      // ===== 文章平铺模式（普通书籍）=====
      chapters.length > 0 && (
        <div class="articles-section">
          <div class="section-header">
            <h2>文章列表</h2>
            <span class="count">共 {chapters.length} 篇文章</span>
          </div>
          <div class="article-list">
            {chapters.map(post => (
              <a href={`/blog/${post.data.slug}`} class="article-item">
                <span class="article-num">{String(post.data.seriesOrder).padStart(2, '0')}</span>
                <span class="article-title">{post.data.title}</span>
                {post.data.date && (
                  <span class="article-date">
                    {new Date(post.data.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' })}
                  </span>
                )}
              </a>
            ))}
          </div>
        </div>
      )
    )}

    {chapters.length === 0 && (
      <div class="empty-notice">
        <p>本书文章尚未上传，敬请期待。</p>
      </div>
    )}
  </div>
</BaseLayout>

<style is:global>
  .book-page { max-width: 960px; margin: 0 auto; padding: 40px 24px 80px; }
  .book-hero { display: flex; gap: 40px; align-items: flex-start; margin-bottom: 48px; }
  .book-cover-img { width: 180px; height: auto; border-radius: 10px; box-shadow: 0 12px 40px rgba(0,0,0,0.13), 0 2px 10px rgba(0,0,0,0.06); }
  .book-tag { font-size: 0.8rem; font-weight: 500; color: var(--color-accent, #f55000); margin-bottom: 8px; }
  .book-details h1 { font-family: var(--font-serif, Georgia, serif); font-size: 1.8rem; font-weight: 700; margin-bottom: 10px; line-height: 1.3; }
  .tagline { font-size: 1rem; color: var(--color-accent, #f55000); font-weight: 500; margin-bottom: 8px; }
  .motto { font-size: 0.95rem; color: var(--color-text-secondary, #888); font-style: italic; margin-bottom: 16px; padding-left: 14px; border-left: 3px solid var(--color-accent, #f55000); }
  .desc { font-size: 0.92rem; color: var(--color-text-secondary, #888); line-height: 1.8; }
  .book-stats { display: flex; gap: 32px; margin-top: 24px; padding-top: 20px; border-top: 1px solid var(--color-border, #e5e5e5); }
  .stat { text-align: center; }
  .stat-num { font-family: var(--font-serif, Georgia, serif); font-size: 1.5rem; font-weight: 700; color: var(--color-text, #1a1a1a); }
  .stat-label { font-size: 0.75rem; color: var(--color-text-secondary, #888); margin-top: 2px; }

  /* 章节折叠模式 */
  .chapters-section { margin-top: 0; }
  .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; padding-bottom: 14px; border-bottom: 2px solid var(--color-accent, #f55000); }
  .section-header h2 { font-family: var(--font-serif, Georgia, serif); font-size: 1.3rem; font-weight: 600; }
  .section-header .count { font-size: 0.85rem; color: var(--color-text-secondary, #888); }
  .chapter-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
  .chapter-card { display: flex; align-items: center; gap: 14px; padding: 18px 20px; background: var(--color-card-bg, #fff); border: 1px solid var(--color-border, #e5e5e5); border-radius: 10px; text-decoration: none; color: var(--color-text, #1a1a1a); transition: all 0.2s ease; }
  .chapter-card:hover { border-color: var(--color-accent, #f55000); box-shadow: 0 4px 20px rgba(245,80,0,0.08); transform: translateY(-2px); }
  .chapter-num { flex-shrink: 0; width: 44px; height: 44px; border-radius: 10px; background: var(--color-accent-light, #fff5f0); color: var(--color-accent, #f55000); display: flex; align-items: center; justify-content: center; font-family: var(--font-serif, Georgia, serif); font-size: 1.05rem; font-weight: 700; }
  .chapter-info { flex: 1; min-width: 0; }
  .chapter-name { font-size: 0.92rem; font-weight: 600; margin-bottom: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .chapter-desc { font-size: 0.75rem; color: var(--color-text-secondary, #888); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .chapter-count { flex-shrink: 0; font-size: 0.78rem; font-weight: 600; color: var(--color-accent, #f55000); background: var(--color-accent-light, #fff5f0); padding: 2px 8px; border-radius: 20px; }
  .chapter-arrow { flex-shrink: 0; color: var(--color-text-secondary, #888); font-size: 1.1rem; transition: transform 0.2s, color 0.2s; }
  .chapter-card:hover .chapter-arrow { transform: translateX(3px); color: var(--color-accent, #f55000); }

  /* 文章平铺模式 */
  .articles-section { margin-top: 0; }
  .article-list { display: flex; flex-direction: column; gap: 6px; }
  .article-item { display: flex; align-items: center; gap: 14px; padding: 14px 18px; border: 1px solid transparent; border-radius: 8px; text-decoration: none; color: var(--color-text, #1a1a1a); transition: all 0.15s; }
  .article-item:hover { background: var(--color-accent-light, #fff5f0); border-color: rgba(245,80,0,0.12); }
  .article-num { flex-shrink: 0; width: 36px; height: 32px; border-radius: 8px; background: var(--color-bg, #fafafa); display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 600; color: var(--color-text-secondary, #888); }
  .article-item:hover .article-num { background: rgba(245,80,0,0.1); color: var(--color-accent, #f55000); }
  .article-title { flex: 1; font-size: 0.92rem; font-weight: 500; }
  .article-item:hover .article-title { color: var(--color-accent, #f55000); }
  .article-date { font-size: 0.75rem; color: var(--color-text-secondary, #888); flex-shrink: 0; }
  .empty-notice { text-align: center; padding: 60px 20px; color: var(--color-text-secondary, #888); font-size: 0.95rem; }

  @media (max-width: 640px) {
    .book-hero { flex-direction: column; align-items: center; text-align: center; }
    .book-cover-img { width: 140px; }
    .motto { border-left: none; padding-left: 0; }
    .book-stats { justify-content: center; }
    .chapter-grid { grid-template-columns: 1fr; }
  }
</style>
