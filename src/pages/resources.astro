---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="资源下载 — 像企业家一样写作">
  <div class="resources-page">
    <div class="resources-inner">

      <div class="resources-header">
        <h1>资源下载</h1>
        <p>精选阅读材料和实用工具，持续更新</p>
      </div>

      <!-- PDF 阅读 -->
      <div class="resource-category">
        <h2>📄 精选阅读</h2>
        <div class="resource-list">
          <div class="resource-item">
            <div class="resource-icon">📄</div>
            <div class="resource-info">
              <strong>深度思考指南</strong>
              <span>PDF · 12 页 · 2026年更新</span>
            </div>
            <a href="/resources/deep-thinking-guide.pdf" class="resource-download" download>下载</a>
          </div>
        </div>
      </div>

      <!-- 手机壁纸 -->
      <div class="resource-category">
        <h2>🖼️ 手机壁纸</h2>
        <div class="resource-list">
          <div class="resource-item">
            <div class="resource-icon">🖼️</div>
            <div class="resource-info">
              <strong>极简系列 · 晨雾</strong>
              <span>高清壁纸 · 适合 OLED 屏幕</span>
            </div>
            <a href="/resources/wallpaper-morning-mist.jpg" class="resource-download" download>下载</a>
          </div>
        </div>
      </div>

      <!-- 工具模板 -->
      <div class="resource-category">
        <h2>🛠️ 工具模板</h2>
        <div class="resource-list">
          <div class="resource-item">
            <div class="resource-icon">🛠️</div>
            <div class="resource-info">
              <strong>写作选题模板</strong>
              <span>Notion 模板 · 可直接复制使用</span>
            </div>
            <a href="/resources/writing-topic-template" class="resource-download">获取</a>
          </div>
        </div>
      </div>

      <p style="text-align:center; color:var(--color-text-secondary); font-size:14px; margin-top:48px;">
        更多资源持续整理中，欢迎关注公众号「种一个梦」获取最新更新
      </p>

    </div>
  </div>
</BaseLayout>
